---
const rawPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/rentals', label: 'Rentals' },
  { href: '/our-work', label: 'Our Work' },
  { href: '/about', label: 'About' },
];

function isActive(linkHref: string) {
  if (linkHref === '/') return rawPath === '/';
  return rawPath === linkHref;
}
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-4 py-3">
    <!-- Logo -->
    <a href="/" class="no-underline">
      <img src="/images/graves-logo.png" alt="Graves Properties" style="height: 75px;" class="w-auto" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a href={link.href}
           class:list={[
             'text-sm font-medium no-underline transition-colors',
             isActive(link.href) ? 'text-slate-900' : 'text-gray-500 hover:text-slate-800'
           ]}>
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right side: phone + CTA -->
    <div class="flex items-center gap-3">
      <a href="tel:+16037852811" class="hidden md:flex items-center gap-1.5 text-sm text-gray-600 hover:text-slate-800 no-underline transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        603-785-2811
      </a>
      <a href="https://bestnhrealty.com"
         class="bg-slate-800 hover:bg-slate-900 text-white text-sm font-semibold px-4 py-2 rounded-lg no-underline transition-colors whitespace-nowrap">
        Sell Your Home &rarr;
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden ml-2 p-2 text-gray-600" aria-label="Open menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-4 pb-4">
    {navLinks.map(link => (
      <a href={link.href}
         class:list={[
           'block py-2.5 text-sm font-medium no-underline border-b border-gray-50',
           isActive(link.href) ? 'text-slate-900' : 'text-gray-500'
         ]}>
        {link.label}
      </a>
    ))}
    <a href="tel:+16037852811" class="block py-2.5 text-sm text-gray-600 no-underline">
      603-785-2811
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
