---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Graves Properties — NH Renovations, Flips & Long-Term Rentals"
  description="Graves Properties renovates, flips, and manages long-term rental properties across New Hampshire. Tim & Katie Graves — 10+ years of hands-on experience on the seacoast and beyond."
>

  <!-- HERO -->
  <section class="bg-slate-900 text-white py-24 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sky-400 text-sm tracking-widest uppercase mb-4">Seacoast NH &middot; Statewide Projects</p>
      <h1 class="font-serif text-4xl md:text-6xl leading-tight mb-6">
        We Renovate, Flip &<br>
        <span class="text-sky-400">Rent Across NH</span>
      </h1>
      <p class="text-slate-300 text-lg md:text-xl max-w-2xl mx-auto mb-10">
        Graves Properties is a husband-and-wife team that buys, renovates, and manages
        rental homes throughout New Hampshire. Over 10 years of hands-on experience —
        every project done right.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/rentals" class="bg-sky-500 hover:bg-sky-600 text-white font-semibold px-8 py-3.5 rounded-xl no-underline transition-colors">
          View Rentals
        </a>
        <a href="/our-work" class="bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-3.5 rounded-xl no-underline transition-colors border border-white/20">
          See Our Work
        </a>
      </div>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl text-slate-900 text-center mb-4">What We Do</h2>
      <p class="text-gray-500 text-center max-w-2xl mx-auto mb-14">
        Three sides of the same mission — finding overlooked properties and turning them into homes people love.
      </p>
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Renovations -->
        <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
          <div class="w-12 h-12 bg-sky-100 text-sky-600 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/></svg>
          </div>
          <h3 class="font-serif text-xl text-slate-900 mb-3">Full Renovations</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            We take on complete gut-renovations — structural, cosmetic, and everything
            in between. Tim handles framing, flooring, and cabinets. Katie does finish
            work that makes houses feel like homes.
          </p>
        </div>
        <!-- Fix & Flip -->
        <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
          <div class="w-12 h-12 bg-sky-100 text-sky-600 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21"/></svg>
          </div>
          <h3 class="font-serif text-xl text-slate-900 mb-3">Fix & Flip</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            We buy distressed properties, do the work ourselves, and resell them as
            move-in ready homes. We've been flipping across NH for over a decade — from
            the seacoast to Keene and everywhere in between.
          </p>
        </div>
        <!-- Rentals -->
        <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
          <div class="w-12 h-12 bg-sky-100 text-sky-600 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"/></svg>
          </div>
          <h3 class="font-serif text-xl text-slate-900 mb-3">Long-Term Rentals</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            We own and manage rental properties statewide. Every rental gets the same
            quality renovation we'd put into a flip — because tenants deserve a home
            they're proud to live in, not just a unit.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- TIM + KATIE INTRO -->
  <section class="py-20 px-4 bg-slate-50">
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-sky-600 text-sm tracking-widest uppercase mb-3">Who We Are</p>
        <h2 class="font-serif text-3xl text-slate-900 mb-5">Tim & Katie Graves</h2>
        <p class="text-gray-600 mb-4 leading-relaxed">
          We bought our first property right out of college — a duplex that needed
          everything. That project brought us together, and we've been renovating
          New Hampshire homes side by side ever since.
        </p>
        <p class="text-gray-600 mb-6 leading-relaxed">
          Tim handles the structural work — framing, flooring, cabinets, and trim.
          Katie is the finish expert — mud, tape, paint, and the design eye that
          turns a house into a home. Together, we've done it all.
        </p>
        <a href="/about" class="text-sky-600 hover:text-sky-700 font-semibold no-underline transition-colors">
          Read our full story &rarr;
        </a>
      </div>
      <div class="bg-slate-200 rounded-2xl aspect-[4/3] flex items-center justify-center">
        <p class="text-slate-400 text-sm">Tim & Katie photo</p>
      </div>
    </div>
  </section>

  <!-- BEST NH REALTY CROSS-LINK -->
  <section class="py-16 px-4 bg-white border-t border-gray-100">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-2xl text-slate-900 mb-3">Looking to Sell Your Home?</h2>
      <p class="text-gray-500 mb-6">
        We also buy houses directly for cash through Best NH Realty — fast closings,
        no commissions, no repairs needed. Same team, different service.
      </p>
      <a href="https://bestnhrealty.com"
         class="inline-block bg-slate-800 hover:bg-slate-900 text-white font-semibold px-8 py-3.5 rounded-xl no-underline transition-colors">
        Visit Best NH Realty &rarr;
      </a>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="py-20 px-4 bg-slate-900 text-white">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-serif text-3xl mb-3">Get in Touch</h2>
      <p class="text-slate-400 mb-8">Have a property to discuss? Want to see a rental? Call or text Tim directly.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16037852811"
           class="bg-sky-500 hover:bg-sky-600 text-white font-semibold px-8 py-3.5 rounded-xl no-underline transition-colors">
          Call 603-785-2811
        </a>
        <a href="mailto:tim@nhgraves.com"
           class="bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-3.5 rounded-xl no-underline transition-colors border border-white/20">
          Email Tim
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
