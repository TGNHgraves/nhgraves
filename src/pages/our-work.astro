---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our Work — Before & After Renovations | Graves Properties NH"
  description="See before and after photos of Graves Properties renovation projects across New Hampshire. Full gut-rehabs, flips, and rental renovations by Tim & Katie Graves."
>

  <!-- HERO -->
  <section class="bg-slate-900 text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sky-400 text-sm tracking-widest uppercase mb-4">Portfolio</p>
      <h1 class="font-serif text-4xl md:text-5xl leading-tight mb-4">
        Our Work
      </h1>
      <p class="text-slate-300 text-lg max-w-2xl mx-auto">
        Before and after — every project tells a story. Here's a look at what
        we've been building across New Hampshire.
      </p>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto space-y-16">

      <!-- Project 1 -->
      <div>
        <h2 class="font-serif text-2xl text-slate-900 mb-2">Seacoast Colonial — Full Gut Renovation</h2>
        <p class="text-gray-500 text-sm mb-6">Complete structural and cosmetic renovation. New framing, flooring, kitchen, and bathrooms.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <div class="bg-slate-200 rounded-xl aspect-[4/3] flex items-center justify-center mb-2">
              <p class="text-slate-400 text-sm">Before photo</p>
            </div>
            <p class="text-xs text-gray-400 uppercase tracking-wider text-center">Before</p>
          </div>
          <div>
            <div class="bg-slate-100 rounded-xl aspect-[4/3] flex items-center justify-center mb-2 border-2 border-sky-200">
              <p class="text-slate-400 text-sm">After photo</p>
            </div>
            <p class="text-xs text-sky-600 uppercase tracking-wider text-center font-semibold">After</p>
          </div>
        </div>
      </div>

      <hr class="border-slate-100" />

      <!-- Project 2 -->
      <div>
        <h2 class="font-serif text-2xl text-slate-900 mb-2">Manchester Duplex — Flip to Rental</h2>
        <p class="text-gray-500 text-sm mb-6">Converted a neglected duplex into two quality long-term rental units. New kitchens, baths, and mechanicals throughout.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <div class="bg-slate-200 rounded-xl aspect-[4/3] flex items-center justify-center mb-2">
              <p class="text-slate-400 text-sm">Before photo</p>
            </div>
            <p class="text-xs text-gray-400 uppercase tracking-wider text-center">Before</p>
          </div>
          <div>
            <div class="bg-slate-100 rounded-xl aspect-[4/3] flex items-center justify-center mb-2 border-2 border-sky-200">
              <p class="text-slate-400 text-sm">After photo</p>
            </div>
            <p class="text-xs text-sky-600 uppercase tracking-wider text-center font-semibold">After</p>
          </div>
        </div>
      </div>

      <hr class="border-slate-100" />

      <!-- Project 3 -->
      <div>
        <h2 class="font-serif text-2xl text-slate-900 mb-2">Keene Ranch — Quick Turnaround Flip</h2>
        <p class="text-gray-500 text-sm mb-6">Cosmetic flip with kitchen remodel, new flooring, and full interior paint. Listed and sold within 30 days of completion.</p>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <div class="bg-slate-200 rounded-xl aspect-[4/3] flex items-center justify-center mb-2">
              <p class="text-slate-400 text-sm">Before photo</p>
            </div>
            <p class="text-xs text-gray-400 uppercase tracking-wider text-center">Before</p>
          </div>
          <div>
            <div class="bg-slate-100 rounded-xl aspect-[4/3] flex items-center justify-center mb-2 border-2 border-sky-200">
              <p class="text-slate-400 text-sm">After photo</p>
            </div>
            <p class="text-xs text-sky-600 uppercase tracking-wider text-center font-semibold">After</p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 bg-slate-50 border-t border-slate-100">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-2xl text-slate-900 mb-3">Have a Property That Needs Work?</h2>
      <p class="text-gray-500 mb-6">
        We're always looking for our next project. If you have a property to sell — in any condition — get in touch.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16037852811"
           class="bg-sky-500 hover:bg-sky-600 text-white font-semibold px-6 py-3 rounded-xl no-underline transition-colors">
          Call 603-785-2811
        </a>
        <a href="https://bestnhrealty.com"
           class="bg-slate-800 hover:bg-slate-900 text-white font-semibold px-6 py-3 rounded-xl no-underline transition-colors">
          Sell Your Home &rarr;
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
