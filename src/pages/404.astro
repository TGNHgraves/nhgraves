---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — Graves Properties"
  description="The page you're looking for doesn't exist."
>
  <section class="py-32 px-4 text-center">
    <h1 class="font-serif text-4xl text-slate-900 mb-4">Page Not Found</h1>
    <p class="text-gray-500 mb-8 max-w-md mx-auto">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/" class="inline-block bg-sky-500 hover:bg-sky-600 text-white font-semibold px-6 py-3 rounded-xl no-underline transition-colors">
      Back to Home
    </a>
  </section>
</BaseLayout>
