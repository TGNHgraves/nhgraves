---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Available Rentals — Graves Properties | NH Rental Properties"
  description="Browse available long-term rental properties from Graves Properties across New Hampshire. Quality-renovated homes managed by Tim & Katie Graves."
>

  <!-- HERO -->
  <section class="bg-slate-900 text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-sky-400 text-sm tracking-widest uppercase mb-4">Rental Listings</p>
      <h1 class="font-serif text-4xl md:text-5xl leading-tight mb-4">
        Available Rentals
      </h1>
      <p class="text-slate-300 text-lg max-w-2xl mx-auto">
        All of our rentals are fully renovated and owner-managed. We take care of
        our properties because we built them ourselves.
      </p>
    </div>
  </section>

  <!-- LISTINGS -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-5xl mx-auto">

      <!-- Empty state -->
      <div class="text-center py-16">
        <div class="w-16 h-16 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"/></svg>
        </div>
        <h2 class="font-serif text-2xl text-slate-900 mb-3">No Listings Available</h2>
        <p class="text-gray-500 max-w-md mx-auto mb-8">
          We don't have any rentals available right now — check back soon!
          We're always working on new properties.
        </p>
        <a href="tel:+16037852811"
           class="inline-block bg-sky-500 hover:bg-sky-600 text-white font-semibold px-6 py-3 rounded-xl no-underline transition-colors">
          Call About Upcoming Rentals
        </a>
      </div>

      <!-- Placeholder cards (hidden, ready for future use) -->
      <div class="hidden grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Example listing card template -->
        <div class="rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
          <div class="bg-slate-200 aspect-[4/3] flex items-center justify-center">
            <p class="text-slate-400 text-sm">Property photo</p>
          </div>
          <div class="p-5">
            <p class="text-sky-600 font-bold text-xl mb-1">$X,XXX/mo</p>
            <h3 class="font-semibold text-slate-900 mb-1">123 Example St, City, NH</h3>
            <p class="text-gray-500 text-sm mb-4">3 bed &middot; 2 bath &middot; 1,400 sqft</p>
            <a href="tel:+16037852811"
               class="block text-center bg-slate-800 hover:bg-slate-900 text-white text-sm font-semibold py-2.5 rounded-lg no-underline transition-colors">
              Contact Us
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
          <div class="bg-slate-200 aspect-[4/3] flex items-center justify-center">
            <p class="text-slate-400 text-sm">Property photo</p>
          </div>
          <div class="p-5">
            <p class="text-sky-600 font-bold text-xl mb-1">$X,XXX/mo</p>
            <h3 class="font-semibold text-slate-900 mb-1">456 Sample Ave, Town, NH</h3>
            <p class="text-gray-500 text-sm mb-4">2 bed &middot; 1 bath &middot; 950 sqft</p>
            <a href="tel:+16037852811"
               class="block text-center bg-slate-800 hover:bg-slate-900 text-white text-sm font-semibold py-2.5 rounded-lg no-underline transition-colors">
              Contact Us
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
          <div class="bg-slate-200 aspect-[4/3] flex items-center justify-center">
            <p class="text-slate-400 text-sm">Property photo</p>
          </div>
          <div class="p-5">
            <p class="text-sky-600 font-bold text-xl mb-1">$X,XXX/mo</p>
            <h3 class="font-semibold text-slate-900 mb-1">789 Demo Rd, Village, NH</h3>
            <p class="text-gray-500 text-sm mb-4">4 bed &middot; 2 bath &middot; 1,800 sqft</p>
            <a href="tel:+16037852811"
               class="block text-center bg-slate-800 hover:bg-slate-900 text-white text-sm font-semibold py-2.5 rounded-lg no-underline transition-colors">
              Contact Us
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 px-4 bg-slate-50 border-t border-slate-100">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-2xl text-slate-900 mb-3">Looking to Sell Instead?</h2>
      <p class="text-gray-500 mb-6">
        We buy houses for cash through Best NH Realty — fast closings, no hassle.
      </p>
      <a href="https://bestnhrealty.com"
         class="inline-block bg-slate-800 hover:bg-slate-900 text-white font-semibold px-6 py-3 rounded-xl no-underline transition-colors">
        Visit Best NH Realty &rarr;
      </a>
    </div>
  </section>

</BaseLayout>
