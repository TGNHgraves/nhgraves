---
const rawPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/rentals', label: 'Rentals' },
  { href: '/our-work', label: 'Our Work' },
  { href: '/about', label: 'About' },
];

function isActive(linkHref: string) {
  if (linkHref === '/') return rawPath === '/';
  return rawPath === linkHref;
}
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-4" style="padding-top:2px;padding-bottom:2px;">
    <!-- Logo -->
    <a href="/" class="no-underline">
      <img src="/images/graves-logo.png" alt="Graves Properties" style="height: 120px;" class="w-auto" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <a href={link.href}
           class:list={[
             'text-sm font-medium no-underline transition-colors',
             isActive(link.href) ? 'text-slate-900' : 'text-gray-500 hover:text-slate-800'
           ]}>
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="flex items-center">
      <a href="https://bestnhrealty.com"
         class="bg-slate-800 hover:bg-slate-900 text-white text-sm font-semibold px-4 py-2 rounded-lg no-underline transition-colors whitespace-nowrap">
        Sell Your Home on Our Sister Site &rarr;
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden ml-2 p-2 text-gray-600" aria-label="Open menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-4 pb-4">
    {navLinks.map(link => (
      <a href={link.href}
         class:list={[
           'block py-2.5 text-sm font-medium no-underline border-b border-gray-50',
           isActive(link.href) ? 'text-slate-900' : 'text-gray-500'
         ]}>
        {link.label}
      </a>
    ))}
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
